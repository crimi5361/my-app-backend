<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PV - <%= data.maquette.filiere %> - Semestre <%= data.semestre.id %></title>
    <style>
        /* Style minimal pour impression */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Times New Roman', Times, serif; 
            font-size: 11px; 
            line-height: 1.3; 
            color: #000; 
            padding: 10px; 
            margin-top: 50px;
        }
        
        /* En-tête */
        .header { 
            text-align: center; 
            margin-bottom: 15px; 
            border-bottom: 2px solid #000; 
            padding-bottom: 8px; 
        }
        .header h1 { 
            font-size: 14px; 
            margin-bottom: 3px; 
            text-transform: uppercase; 
        }
        .header h2 { 
            font-size: 12px; 
            font-weight: normal; 
            margin: 3px 0; 
        }
        
        /* Informations */
        .info-box { 
            margin: 12px 0; 
            border: 1px solid #000; 
            padding: 6px; 
        }
        .info-table { 
            width: 100%; 
            border-collapse: collapse; 
        }
        .info-table td { 
            padding: 4px 8px; 
            vertical-align: top; 
        }
        .info-label { 
            font-weight: bold; 
            white-space: nowrap; 
        }
        
        /* Boutons de navigation entre tableaux */
        .table-nav {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 20px 0;
        }
        .nav-btn {
            padding: 8px 20px;
            background-color: #f0f0f0;
            border: 1px solid #000;
            cursor: pointer;
            font-weight: bold;
            border-radius: 4px;
        }
        .nav-btn:hover {
            background-color: #ddd;
        }
        .nav-btn.active {
            background-color: #2196F3;
            color: white;
            border-color: #1976D2;
        }
        
        /* Classes pour l'impression sélective */
        .print-only-pv .reprise-container,
        .print-only-reprise .pv-section {
            display: none !important;
        }
        
        .print-only-pv .pv-section,
        .print-only-reprise .reprise-container {
            display: block !important;
        }
        
        /* Tableau principal */
        .main-container { 
            margin: 15px 0; 
            overflow-x: auto; 
        }
        .main-table { 
            width: 100%; 
            border-collapse: collapse; 
            border: 2px solid #000; 
            table-layout: auto;
        }
        
        /* En-tête du tableau principal */
        .table-header th { 
            background-color: #f0f0f0; 
            border: 1px solid #000; 
            padding: 6px 2px; 
            text-align: center; 
            font-weight: bold; 
            vertical-align: middle; 
        }
        
        /* Première ligne d'en-tête */
        .header-row-1 th { 
            border-bottom: 2px solid #000; 
            padding: 8px 2px; 
        }
        
        /* Noms des UE */
        .ue-header { 
            background-color: #e8e8e8 !important; 
            font-size: 10px; 
            padding: 4px 2px !important; 
        }
        
        /* Noms des matières */
        .matiere-header { 
            background-color: #f8f8f8 !important; 
            font-size: 9px; 
            padding: 4px 1px !important; 
            white-space: normal;
            word-break: break-word;
            line-height: 1.2; 
            min-width: 25px;
        }
        
        /* En-tête pour les types de notes */
        .note-type-header {
            background-color: #e0e0e0 !important;
            font-size: 8px;
            font-weight: normal;
            padding: 2px 1px !important;
        }
        
        /* Cellules des étudiants */
        .student-row td { 
            border: 1px solid #000; 
            padding: 5px 2px; 
            text-align: center; 
            vertical-align: middle; 
            transition: all 0.2s ease;
        }
        
        /* Style pour les lignes censurées */
        .student-row.censure-active td:not(.student-info) {
            background-color: #000000 !important;
            color: #000000 !important;
            border-color: #333333 !important;
            position: relative;
        }
        
        .student-row.censure-active td:not(.student-info) span,
        .student-row.censure-active td:not(.student-info) strong {
            color: #000000 !important;
            background-color: #000000 !important;
        }
        
        .student-row.censure-active td.student-info {
            background-color: #ffffff;
        }
        
        .student-row.censure-active td:not(.student-info):hover::after {
            content: "Scolarité NON SOLDE";
            position: absolute;
            background: #ff0000;
            color: white;
            font-size: 8px;
            padding: 2px 4px;
            border-radius: 2px;
            bottom: 100%;
            left: 0;
            white-space: nowrap;
            z-index: 10;
        }
        
        /* Colonne étudiant combinée */
        .student-info { 
            text-align: left; 
            padding-left: 4px !important; 
        }
        .matricule { 
            font-size: 9px; 
            color: #555; 
            display: block; 
            margin-top: 2px; 
        }
        
        /* Cellules de notes */
        .note-cell { 
            font-weight: bold; 
            min-width: 20px; 
            font-size: 10px; 
            white-space: nowrap;
            padding: 5px 1px !important;
            position: relative;
        }
        
        /* Couleurs pour notes */
        .note-valide {
            color: #006600;
            font-weight: bold;
        }
        .note-non-valide {
            color: #cc0000;
        }
        
        /* Suppression de la mention H pour notes harmonisées */
        .harmonisee {
            /* Pas de style spécifique pour éviter l'affichage du H */
        }

        .non-solde-text {
            color: #ff4444;
            font-weight: bold;
        }
        
        /* Résultat UE */
        .resultat-ue { 
            background-color: #f5f5f5; 
            font-weight: bold; 
            border-left: 2px solid #000 !important; 
            border-right: 2px solid #000 !important; 
            white-space: nowrap;
            min-width: 30px;
            color: #000 !important;
        }
        
        /* Décision */
        .decision-cell { 
            font-weight: bold; 
            text-transform: uppercase; 
            font-size: 10px; 
            color: #000 !important;
        }
        
        /* Barre d'outils */
        .toolbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: white;
            padding: 8px 15px;
            border-bottom: 2px solid #000;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 12px;
            flex-wrap: wrap;
        }
        
        .toolbar button {
            padding: 8px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: all 0.2s;
        }
        
        .btn-print {
            background-color: #2196F3;
            color: white;
        }
        
        .btn-print-pv {
            background-color: #4CAF50;
            color: white;
        }
        
        .btn-print-reprise {
            background-color: #ff9800;
            color: white;
        }
        
        .btn-print:hover, .btn-print-pv:hover, .btn-print-reprise:hover {
            opacity: 0.8;
        }
        
        .btn-censure {
            background-color: #ff4444;
            color: white;
            position: relative;
            min-width: 180px;
        }
        
        .btn-censure.active {
            background-color: #4CAF50;
        }
        
        .btn-censure.active:hover {
            background-color: #45a049;
        }
        
        .btn-censure:hover {
            background-color: #cc0000;
        }
        
        .btn-censure .badge {
            background-color: white;
            color: #ff4444;
            border-radius: 50%;
            padding: 2px 6px;
            margin-left: 8px;
            font-size: 10px;
            font-weight: bold;
        }
        
        .btn-censure.active .badge {
            background-color: #4CAF50;
            color: white;
        }
        
        .status-indicator {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .status-badge {
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
        }
        
        .status-badge.solde {
            background-color: #4CAF50;
            color: white;
        }
        
        .status-badge.non-solde {
            background-color: #ff4444;
            color: white;
        }
        
        /* Légende enrichie avec statistiques */
        .legend {
            margin-top: 15px;
            font-size: 9px;
            color: #555;
            padding: 8px;
            background-color: #f9f9f9;
            border: 1px solid #ddd;
            border-radius: 4px;
        }
        
        .legend p {
            margin: 5px 0;
        }
        
        .legend .stats-line {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-top: 8px;
            padding-top: 8px;
            border-top: 1px dashed #ccc;
            font-size: 9px;
        }
        
        .legend .stats-item {
            color: #333;
        }
        
        .legend .stats-item.admis {
            color: #006600;
        }
        
        .legend .stats-item.ajourne {
            color: #cc0000;
        }
        
        .legend .stats-item.reprise {
            color: #cc0000;
        }
        
        .legend span {
            display: inline-block;
            margin-right: 15px;
        }
        
        .legend .censure-indicator {
            display: inline-flex;
            align-items: center;
            gap: 3px;
        }
        
        .censure-indicator .square {
            width: 12px;
            height: 12px;
            background-color: #000;
            display: inline-block;
            margin-right: 2px;
        }
        
        .rang-cell {
            font-weight: bold;
            background-color: #f5f5f5;
            color: #000 !important;
        }
        
        /* ===== TABLEAU DES REPRISES AMÉLIORÉ ===== */
        .reprise-container {
            margin: 30px 0;
            page-break-before: always;
        }
        
        .reprise-header {
            text-align: center;
            margin: 20px 0 25px;
            padding: 15px;
            background: linear-gradient(to right, #fff9f9, #fff0f0);
            border: 2px solid #cc0000;
            border-radius: 8px;
        }
        
        .reprise-header h2 {
            font-size: 18px;
            text-transform: uppercase;
            color: #cc0000;
            margin-bottom: 8px;
            font-weight: bold;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
        }
        
        .reprise-header h3 {
            font-size: 14px;
            color: #333;
            margin: 5px 0;
        }
        
        .reprise-header p {
            font-size: 12px;
            color: #666;
            font-style: italic;
        }
        
        .reprise-table {
            width: 100%;
            border-collapse: collapse;
            border: 2px solid #000;
            margin-top: 15px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        
        .reprise-table th {
            background: linear-gradient(to bottom, #f0f0f0, #e0e0e0);
            border: 1px solid #000;
            padding: 10px 4px;
            text-align: center;
            font-weight: bold;
            font-size: 11px;
            text-transform: uppercase;
        }
        
        .reprise-table td {
            border: 1px solid #000;
            padding: 8px 4px;
            vertical-align: top;
            font-size: 10px;
        }
        
        .reprise-etudiant {
            background-color: #fff9f9;
        }
        
        .reprise-etudiant:hover {
            background-color: #fff0f0;
        }
        
        .reprise-etudiant td:first-child {
            font-weight: bold;
            text-align: center;
            background-color: #f5f5f5;
        }
        
        .reprise-list {
            list-style: none;
            margin: 0;
            padding: 0;
        }
        
        .reprise-list li {
            margin: 5px 0;
            padding: 5px;
            background-color: #fff0f0;
            border-left: 3px solid #cc0000;
            border-radius: 0 4px 4px 0;
        }
        
        .reprise-list li:last-child {
            margin-bottom: 0;
        }
        
        .reprise-matiere {
            font-weight: bold;
            color: #333;
        }
        
        .reprise-note {
            color: #cc0000;
            font-weight: bold;
            margin-left: 5px;
            background-color: #ffe0e0;
            padding: 2px 5px;
            border-radius: 3px;
        }
        
        .reprise-coef {
            color: #666;
            font-size: 9px;
            margin-left: 5px;
            font-style: italic;
        }
        
        .reprise-ue {
            display: block;
            color: #666;
            font-size: 9px;
            margin-top: 2px;
        }
        
        .reprise-count-badge {
            display: inline-block;
            background-color: #cc0000;
            color: white;
            border-radius: 20px;
            padding: 4px 10px;
            font-size: 10px;
            font-weight: bold;
            box-shadow: 0 2px 4px rgba(204,0,0,0.3);
        }
        
        .reprise-summary {
            margin-top: 20px;
            padding: 15px;
            background: linear-gradient(to right, #f0f0f0, #e8e8e8);
            border: 2px solid #000;
            border-radius: 6px;
            font-weight: bold;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
        }
        
        .reprise-summary p {
            margin: 0;
            font-size: 11px;
        }
        
        .reprise-summary strong {
            color: #cc0000;
        }
        
        .reprise-legend {
            margin-top: 15px;
            padding: 10px;
            background-color: #fff9f9;
            border: 1px dashed #cc0000;
            border-radius: 4px;
        }
        
        /* Style pour les ECUE avec note éliminatoire */
        .note-eliminatoire {
            border-left: 3px solid #cc0000 !important;
            background-color: #fff0f0;
        }
        
        /* Pour l'impression */
        @media print {
            body { 
                padding: 5px; 
                font-size: 10px;
                margin-top: 0;
            }
            .toolbar { 
                display: none !important; 
            }
            .table-nav { 
                display: none !important; 
            }
            .main-container { 
                overflow-x: visible; 
            }
            .main-table { 
                font-size: 9px; 
            }
            .reprise-container {
                page-break-before: always;
            }
            .reprise-header {
                background: none;
                border: 2px solid #000;
            }
            .student-row.censure-active td:not(.student-info) {
                background-color: #000000 !important;
                color: #000000 !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
            
            /* Impression sélective */
            body.print-pv-only .reprise-container,
            body.print-reprise-only .pv-section {
                display: none !important;
            }
            
            body.print-pv-only .pv-section,
            body.print-reprise-only .reprise-container {
                display: block !important;
            }
        }
    </style>
</head>
<body>
    <!-- Barre d'outils -->
    <div class="toolbar no-print">
        <div style="display: flex; gap: 10px;">
            <button class="btn-print" onclick="window.print()">
                🖨️ Imprimer tout
            </button>
            <button class="btn-print-pv" onclick="printSection('pv')">
                🖨️ Imprimer PV uniquement
            </button>
            <button class="btn-print-reprise" onclick="printSection('reprise')">
                🖨️ Imprimer Reprises uniquement
            </button>
        </div>
        
        <button id="toggleCensure" class="btn-censure active" title="Cliquez pour afficher/masquer les étudiants NON_SOLDE">
            Masquer les NON_SOLDE
            <span class="badge" id="nonSoldeCount"><%= data.statistiques.statistiques_scolarite.total_non_solde %></span>
        </button>
        
        <div class="table-nav">
            <button id="showPV" class="nav-btn active" onclick="showTable('pv')"> PV Principal</button>
            <button id="showReprise" class="nav-btn" onclick="showTable('reprise')"> Tableau des Reprises</button>
        </div>
        
        <div class="status-indicator">
            <span class="status-badge solde">
                SOLDE: <%= data.statistiques.statistiques_scolarite.total_solde %>
            </span>
            <span class="status-badge non-solde">
                NON_SOLDE: <%= data.statistiques.statistiques_scolarite.total_non_solde %>
            </span>
        </div>
    </div>

    <!-- SECTION 1: PV PRINCIPAL -->
    <div id="pv-section" class="pv-section">
        <div class="header">
            <h1>PROCÈS-VERBAL DE DÉLIBÉRATION</h1>
            <h2><%= data.maquette.filiere %> (<%= data.maquette.sigle %>)</h2>
            <h2>Année académique <%= data.groupe.annee_academique %></h2>
        </div>

        <div class="info-box">
            <table class="info-table">
                 <tr>
                    <td class="info-label">Type de filière:</td>
                    <td><%= data.type_filiere %></td>
                    <td class="info-label">Parcours:</td>
                    <td><%= data.maquette.parcour || '-' %></td>
                </tr>
                <tr>
                    <td class="info-label">Semestre:</td>
                    <td>Semestre <%= data.semestre.id %></td>
                    <td class="info-label">Groupe:</td>
                    <td><%= data.groupe.nom %></td>
                </tr>
            </table>
        </div>

        <div class="main-container">
            <table class="main-table">
                <thead>
                    <tr class="table-header header-row-1">
                        <th rowspan="4" width="2%">N°</th>
                        <th rowspan="4" width="7%">ÉTUDIANT</th>
                        
                        <% if (data.etudiants && data.etudiants.length > 0 && data.etudiants[0].ues) { 
                            data.etudiants[0].ues.forEach((ue) => { 
                                const matieresCount = ue.matieres.length; %>
                                
                                <!-- Utilisation du type_traitement pour le nombre de colonnes -->
                                <% if (data.type_traitement === 'universitaire') { %>
                                    <th colspan="<%= (matieresCount * 2) + 1 %>" class="ue-header">
                                        <%= ue.libelle %>
                                    </th>
                                <% } else { %>
                                    <th colspan="<%= matieresCount + 1 %>" class="ue-header">
                                        <%= ue.libelle %>
                                    </th>
                                <% } %>
                        <%  }); 
                        } %>
                        
                        <!-- Pour les filières professionnelles : RANG avant MOY. GÉN. -->
                        <% if (data.type_traitement === 'professionnel') { %>
                            <th rowspan="4" width="2%">RANG</th>
                        <% } %>
                        
                        <th rowspan="4" width="2%">MOY.<br>GÉN.</th>
                        
                        <!-- Utilisation du type_traitement pour l'affichage des crédits -->
                        <% if (data.type_traitement === 'universitaire') { %>
                            <th rowspan="4" width="3%">CRÉDITS<br>V/T</th>
                        <% } %>
                        
                        <th rowspan="4" width="4%">DÉCISION</th>
                    </tr>
                    
                    <tr class="table-header">
                        <% if (data.etudiants && data.etudiants.length > 0 && data.etudiants[0].ues) { 
                            data.etudiants[0].ues.forEach((ue) => { 
                                ue.matieres.forEach((matiere) => { %>
                                    
                                    <!-- Utilisation du type_traitement pour l'affichage des matières -->
                                    <% if (data.type_traitement === 'universitaire') { %>
                                        <th class="matiere-header" colspan="2" title="<%= matiere.nom %>">
                                            <%= matiere.nom %>
                                        </th>
                                    <% } else { %>
                                        <th class="matiere-header" title="<%= matiere.nom %>">
                                            <%= matiere.nom %>
                                        </th>
                                    <% } %>
                        <%      }); %>
                                <th class="matiere-header resultat-ue">RÉSULTAT</th>
                        <%  }); 
                        } %>
                        <!-- Pas de colonne supplémentaire pour RANG ici car elle est dans header-row-1 -->
                    </tr>
                    
                    <tr class="table-header">
                        <% if (data.etudiants && data.etudiants.length > 0 && data.etudiants[0].ues) { 
                            data.etudiants[0].ues.forEach((ue) => { 
                                ue.matieres.forEach(() => { %>
                                    
                                    <!-- Utilisation du type_traitement pour les types de notes -->
                                    <% if (data.type_traitement === 'universitaire') { %>
                                        <th class="note-type-header">CC</th>
                                        <th class="note-type-header">Exam</th>
                                    <% } else { %>
                                        <th class="note-type-header">Note</th>
                                    <% } %>
                        <%      }); %>
                                <th class="note-type-header">Moy.</th>
                        <%  }); 
                        } %>
                    </tr>
                    
                    <tr class="table-header">
                        <% if (data.etudiants && data.etudiants.length > 0 && data.etudiants[0].ues) { 
                            data.etudiants[0].ues.forEach((ue) => { 
                                ue.matieres.forEach((matiere) => { %>
                                    
                                    <!-- Utilisation du type_traitement pour les coefficients -->
                                    <% if (data.type_traitement === 'universitaire') { %>
                                        <th class="note-type-header" colspan="2">coef: <%= matiere.coefficient %></th>
                                    <% } else { %>
                                        <th class="note-type-header">coef: <%= matiere.coefficient %></th>
                                    <% } %>
                        <%      }); %>
                                <th class="note-type-header">-</th>
                        <%  }); 
                        } %>
                    </tr>
                </thead>
                
                <tbody>
                    <% data.etudiants.forEach((etudiant, etudiantIndex) => { 
                        const estNonSolde = !etudiant.scolarite_soldee;
                    %>
                    <tr class="student-row <%= estNonSolde ? 'non-solde' : '' %>" 
                        data-scolarite="<%= etudiant.scolarite_soldee ? 'solde' : 'non-solde' %>">
                        
                        <td><%= etudiantIndex + 1 %></td>
                        <td class="student-info">
                            <strong><%= etudiant.nom %> <%= etudiant.prenoms %></strong>
                            <span class="matricule"><%= etudiant.matricule_iipea %></span>
                        </td>
                        
                        <!-- Notes par matière -->
                        <% etudiant.ues.forEach((ue) => { 
                            const ueValidee = ue.moyenne_affichage >= 10;
                            
                            ue.matieres.forEach((matiere) => { 
                                let moyenneECUE = null;
                                let moyenneOriginale = null;
                                
                                if (matiere.harmonisee && matiere.moyenne_affichage !== undefined) {
                                    moyenneECUE = matiere.moyenne_affichage;
                                    moyenneOriginale = matiere.moyenne_originale;
                                } else if (matiere.moyenne_pro !== undefined && matiere.moyenne_pro !== null) {
                                    moyenneECUE = matiere.moyenne_pro;
                                    moyenneOriginale = matiere.moyenne_pro;
                                } else if (matiere.moyenne !== undefined && matiere.moyenne !== null) {
                                    moyenneECUE = matiere.moyenne;
                                    moyenneOriginale = matiere.moyenne;
                                }
                            %>
                                
                                <!-- Utilisation du type_traitement pour l'affichage des notes -->
                                <% if (data.type_traitement === 'universitaire') { %>
                                    <!-- Colonne CC -->
                                    <td class="note-cell">
                                        <% 
                                            let ccValue = null;
                                            let ccOriginal = null;
                                            let ccHarmonisee = false;
                                            
                                            if (matiere.harmonisee && matiere.cc_affichage !== undefined) {
                                                ccValue = matiere.cc_affichage;
                                                ccOriginal = matiere.cc_original;
                                                ccHarmonisee = true;
                                            } else if (matiere.moyenne_cc !== undefined && matiere.moyenne_cc !== null) {
                                                ccValue = matiere.moyenne_cc;
                                                ccOriginal = matiere.moyenne_cc;
                                            }
                                            
                                            let classeCouleur = '';
                                            if (ueValidee) {
                                                classeCouleur = 'note-valide';
                                            } else {
                                                classeCouleur = (moyenneECUE !== null && moyenneECUE >= 10) ? 'note-valide' : 'note-non-valide';
                                            }
                                        %>
                                        <% if (ccValue !== null && ccValue !== undefined) { %>
                                            <span class="<%= classeCouleur %>" 
                                                  title="CC original: <%= ccOriginal !== null ? ccOriginal.toFixed(2) : '-' %> | Moyenne ECUE originale: <%= moyenneOriginale !== null ? moyenneOriginale.toFixed(2) : '-' %>">
                                                <%= ccValue.toFixed(2) %>
                                            </span>
                                        <% } else { %>
                                            <span style="color: #888; font-style: italic;">-</span>
                                        <% } %>
                                    </td>
                                    
                                    <!-- Colonne Examen -->
                                    <td class="note-cell">
                                        <% 
                                            let examenValue = null;
                                            let examenOriginal = null;
                                            let examenHarmonisee = false;
                                            
                                            if (matiere.harmonisee && matiere.examen_affichage !== undefined) {
                                                examenValue = matiere.examen_affichage;
                                                examenOriginal = matiere.examen_original;
                                                examenHarmonisee = true;
                                            } else if (matiere.partiel !== undefined && matiere.partiel !== null) {
                                                examenValue = matiere.partiel;
                                                examenOriginal = matiere.partiel;
                                            }
                                            
                                            let classeCouleurExamen = '';
                                            if (ueValidee) {
                                                classeCouleurExamen = 'note-valide';
                                            } else {
                                                classeCouleurExamen = (moyenneECUE !== null && moyenneECUE >= 10) ? 'note-valide' : 'note-non-valide';
                                            }
                                        %>
                                        <% if (examenValue !== null && examenValue !== undefined) { %>
                                            <span class="<%= classeCouleurExamen %>" 
                                                  title="Examen original: <%= examenOriginal !== null ? examenOriginal.toFixed(2) : '-' %> | Moyenne ECUE originale: <%= moyenneOriginale !== null ? moyenneOriginale.toFixed(2) : '-' %>">
                                                <%= examenValue.toFixed(2) %>
                                            </span>
                                        <% } else { %>
                                            <span style="color: #888; font-style: italic;">-</span>
                                        <% } %>
                                    </td>
                                <% } else { %>
                                    <!-- Professionnelle: une seule note -->
                                    <td class="note-cell">
                                        <% 
                                            let profValue = null;
                                            let profOriginal = null;
                                            let profHarmonisee = false;
                                            
                                            if (matiere.harmonisee && matiere.moyenne_affichage !== undefined) {
                                                profValue = matiere.moyenne_affichage;
                                                profOriginal = matiere.moyenne_originale;
                                                profHarmonisee = true;
                                            } else if (matiere.moyenne_pro !== undefined && matiere.moyenne_pro !== null) {
                                                profValue = matiere.moyenne_pro;
                                                profOriginal = matiere.moyenne_pro;
                                            } else if (matiere.moyenne !== undefined && matiere.moyenne !== null) {
                                                profValue = matiere.moyenne;
                                                profOriginal = matiere.moyenne;
                                            }
                                            
                                            let classeCouleurProf = '';
                                            if (ueValidee) {
                                                classeCouleurProf = 'note-valide';
                                            } else {
                                                classeCouleurProf = (profValue !== null && profValue >= 10) ? 'note-valide' : 'note-non-valide';
                                            }
                                        %>
                                        <% if (profValue !== null && profValue !== undefined) { %>
                                            <span class="<%= classeCouleurProf %>" 
                                                  title="Note originale: <%= profOriginal !== null ? profOriginal.toFixed(2) : '-' %>">
                                                <%= profValue.toFixed(2) %>
                                            </span>
                                        <% } else { %>
                                            <span style="color: #888; font-style: italic;">-</span>
                                        <% } %>
                                    </td>
                                <% } %>
                        <%  }); %>
                        
                            <!-- Résultat UE -->
                            <td class="note-cell resultat-ue">
                                <% 
                                    const moyenneUE = ue.moyenne_affichage !== undefined ? ue.moyenne_affichage : ue.moyenne;
                                    const estHarmonisee = ue.harmonisee || false;
                                    const moyenneOriginaleUE = ue.moyenne !== undefined ? ue.moyenne.toFixed(2) : '-';
                                %>
                                <strong class="<%= estHarmonisee ? '' : '' %>" 
                                        title="Moyenne originale UE: <%= moyenneOriginaleUE %>">
                                    <%= moyenneUE.toFixed(2) %>
                                </strong>
                            </td>
                        <% }); %>
                        
                        <!-- Pour les filières professionnelles : RANG avant MOY. GÉN. -->
                        <% if (data.type_traitement === 'professionnel') { %>
                            <td class="rang-cell"><%= etudiantIndex + 1 %></td>
                        <% } %>
                        
                        <!-- Moyenne générale -->
                        <td class="note-cell">
                            <strong><%= etudiant.moyenne_generale %></strong>
                        </td>
                        
                        <!-- Crédits - Utilisation du type_traitement -->
                        <% if (data.type_traitement === 'universitaire') { %>
                            <td class="note-cell">
                                <%= etudiant.credits_valides %>/<%= etudiant.credits_total %>
                            </td>
                        <% } %>
                        
                        <!-- Décision -->
                        <td class="decision-cell">
                            <%= etudiant.decision %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>

        <!-- Légende enrichie avec statistiques discrètes -->
        <div class="legend">
            <p>
                <span><strong>Légende:</strong></span>
                
                <!-- Utilisation du type_traitement pour la légende -->
                <% if (data.type_traitement === 'universitaire') { %>
                    <span>CC = Moyenne (note1 + note2)/2</span>
                    <span>Exam = Note partiel</span>
                <% } %>
                
                <span>Moy. = Moyenne UE</span>
                <span style="color: #006600;">Vert = ECUE validé (moyenne ≥ 10)</span>
                <span style="color: #cc0000;">Rouge = ECUE non validé (moyenne < 10)</span>
                <% if (data.type_traitement === 'universitaire') { %>
                    <span style="color: #006600; font-weight: bold;"> Si UE ≥ 10 → TOUS les ECUE de l'UE sont VERTS</span>
                <% } %>
                
                <span class="censure-indicator">
                    <span class="square"></span> = Scolarité NON SOLDE 
                </span>
            </p>
            
            <!-- Statistiques discrètes intégrées à la légende -->
            <div class="stats-line">
                <span class="stats-item"> Total: <strong><%= data.statistiques.total_etudiants %></strong></span>
                <span class="stats-item admis">Admis: <strong><%= data.statistiques.total_admis %></strong></span>
                <span class="stats-item ajourne"> Ajournés: <strong><%= data.statistiques.total_ajournes %></strong></span>
                <span class="stats-item">UE: <strong><%= data.statistiques.total_ue %></strong></span>
                <span class="stats-item"> Crédits: <strong><%= data.statistiques.total_credits_maquette %></strong></span>
                <span class="stats-item reprise">À reprendre: <strong><%= data.statistiques.statistiques_reprise.total_etudiants_a_reprendre %> étudiants, <%= data.statistiques.statistiques_reprise.total_ecue_a_reprendre %> ECUE</strong></span>
            </div>
            
            <p style="margin-top: 5px; color: #777; font-style: italic;">
                Généré le <%= new Date().toLocaleDateString('fr-FR') %>
            </p>
        </div>
    </div>

    <!-- SECTION 2: TABLEAU DES REPRISES -->
    <div id="reprise-section" class="reprise-container" style="display: none;">
        <div class="reprise-header">
            <h2>📝 LISTE DES ÉTUDIANTS AYANT DES ECUE À REPRENDRE</h2>
            <h3><%= data.maquette.filiere %> - Semestre <%= data.semestre.id %> - Groupe <%= data.groupe.nom %></h3>
            <p>Année académique <%= data.groupe.annee_academique %></p>
        </div>

        <% if (data.etudiants_a_reprendre && data.etudiants_a_reprendre.length > 0) { %>
            <table class="reprise-table">
                <thead>
                    <tr>
                        <th width="5%">N°</th>
                        <th width="12%">Matricule</th>
                        <th width="18%">Étudiant</th>
                        <th width="45%">ECUE à reprendre (moyenne originale < 10)</th>
                        <th width="10%">Total</th>
                        <th width="10%">Décision</th>
                    </tr>
                </thead>
                <tbody>
                    <% data.etudiants_a_reprendre.forEach((etudiant, index) => { %>
                        <tr class="reprise-etudiant">
                            <td><%= index + 1 %></td>
                            <td><strong><%= etudiant.matricule_iipea %></strong></td>
                            <td>
                                <strong><%= etudiant.nom %> <%= etudiant.prenoms %></strong>
                                <% if (!etudiant.scolarite_soldee) { %>
                                    <br><span style="color: #ff4444; font-size: 9px;">⚠️ NON SOLDE</span>
                                <% } %>
                            </td>
                            <td>
                                <ul class="reprise-list">
                                    <% etudiant.ecue_a_reprendre.forEach((ecue) => { %>
                                        <li>
                                            <span class="reprise-matiere"><%= ecue.matiere_nom %></span>
                                            <span class="reprise-note"><%= ecue.moyenne.toFixed(2) %></span>
                                            <span class="reprise-coef">coef: <%= ecue.coefficient %></span>
                                            <span class="reprise-ue">📌 UE: <%= ecue.ue_libelle %></span>
                                            <% if (ecue.harmonisee) { %>
                                                <span style="color: #666; font-size: 8px; margin-left: 5px;">(harmonisé)</span>
                                            <% } %>
                                            <% if (ecue.cc_original && ecue.examen_original) { %>
                                                <br><small style="color: #666;">CC: <%= ecue.cc_original.toFixed(2) %> | Exam: <%= ecue.examen_original.toFixed(2) %></small>
                                            <% } %>
                                        </li>
                                    <% }); %>
                                </ul>
                            </td>
                            <td style="text-align: center; vertical-align: middle;">
                                <span class="reprise-count-badge"><%= etudiant.ecue_a_reprendre.length %></span>
                            </td>
                            <td style="text-align: center; vertical-align: middle; <%= etudiant.decision === 'AJOURNÉ' ? 'color: #cc0000; font-weight: bold;' : '' %>">
                                <%= etudiant.decision %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>

            <div class="reprise-summary">
                <p><strong>📊 Total étudiants concernés :</strong> <%= data.statistiques.statistiques_reprise.total_etudiants_a_reprendre %></p>
                <p><strong>📚 Total ECUE à reprendre :</strong> <%= data.statistiques.statistiques_reprise.total_ecue_a_reprendre %></p>
                <p><strong>📈 Moyenne par étudiant :</strong> <%= (data.statistiques.statistiques_reprise.total_ecue_a_reprendre / data.statistiques.statistiques_reprise.total_etudiants_a_reprendre).toFixed(1) %> ECUE</p>
            </div>

            <div class="reprise-legend">
                <p style="margin: 0;">
                    <span style="color: #cc0000; font-weight: bold;">⚠️ Note :</span> 
                    Ces ECUE sont à reprendre car ils appartiennent à des UE non validées (moyenne UE < 10) et ont une moyenne originale < 10.
                    Les ECUE des UE validées (moyenne UE ≥ 10) ne sont pas à reprendre, même si leur note originale était < 10.
                </p>
            </div>
        <% } else { %>
            <div style="text-align: center; padding: 50px; border: 2px solid #006600; border-radius: 8px; margin-top: 30px; background-color: #f0fff0;">
                <h3 style="color: #006600; font-size: 16px;">✅ Aucun étudiant n'a d'ECUE à reprendre</h3>
                <p style="margin-top: 10px; color: #333;">Tous les étudiants ont validé tous leurs ECUE ou sont admis</p>
            </div>
        <% } %>
    </div>

    <!-- Script -->
    <script class="no-print">
        document.addEventListener('DOMContentLoaded', function() {
            const toggleBtn = document.getElementById('toggleCensure');
            const nonSoldeCount = document.getElementById('nonSoldeCount');
            const legendState = document.getElementById('legendCensureState');
            const pvSection = document.getElementById('pv-section');
            const repriseSection = document.getElementById('reprise-section');
            const showPVBtn = document.getElementById('showPV');
            const showRepriseBtn = document.getElementById('showReprise');
            
            let censureActive = true;
            
            appliquerCensure(true);
            
            function appliquerCensure(activer) {
                const lignesNonSolde = document.querySelectorAll('tr.student-row[data-scolarite="non-solde"]');
                
                lignesNonSolde.forEach(ligne => {
                    if (activer) {
                        ligne.classList.add('censure-active');
                    } else {
                        ligne.classList.remove('censure-active');
                    }
                });
                
                if (activer) {
                    toggleBtn.innerHTML = 'Masquer les NON_SOLDE <span class="badge" id="nonSoldeCount">' + 
                        '<%= data.statistiques.statistiques_scolarite.total_non_solde %></span>';
                    toggleBtn.classList.add('active');
                    toggleBtn.title = "Cliquez pour afficher les étudiants NON_SOLDE";
                    if (legendState) legendState.textContent = '(Masqué)';
                } else {
                    toggleBtn.innerHTML = '👁️ Afficher les NON_SOLDE <span class="badge" id="nonSoldeCount">' + 
                        '<%= data.statistiques.statistiques_scolarite.total_non_solde %></span>';
                    toggleBtn.classList.remove('active');
                    toggleBtn.title = "Cliquez pour masquer les étudiants NON_SOLDE";
                    if (legendState) legendState.textContent = '(Affiché)';
                }
                
                censureActive = activer;
            }
            
            toggleBtn.addEventListener('click', function() {
                appliquerCensure(!censureActive);
            });
            
            window.showTable = function(table) {
                if (table === 'pv') {
                    pvSection.style.display = 'block';
                    repriseSection.style.display = 'none';
                    showPVBtn.classList.add('active');
                    showRepriseBtn.classList.remove('active');
                } else {
                    pvSection.style.display = 'none';
                    repriseSection.style.display = 'block';
                    showPVBtn.classList.remove('active');
                    showRepriseBtn.classList.add('active');
                }
            };
            
            // Fonction pour imprimer uniquement une section
            window.printSection = function(section) {
                const body = document.body;
                
                if (section === 'pv') {
                    body.classList.add('print-pv-only');
                    body.classList.remove('print-reprise-only');
                } else {
                    body.classList.add('print-reprise-only');
                    body.classList.remove('print-pv-only');
                }
                
                window.print();
                
                // Nettoyer après impression
                setTimeout(() => {
                    body.classList.remove('print-pv-only', 'print-reprise-only');
                }, 100);
            };
            
            window.onbeforeprint = function() {
                // Sauvegarder l'état d'affichage
                const pvDisplay = pvSection.style.display;
                const repriseDisplay = repriseSection.style.display;
                
                // Afficher les deux sections pour l'impression complète
                if (!document.body.classList.contains('print-pv-only') && !document.body.classList.contains('print-reprise-only')) {
                    pvSection.style.display = 'block';
                    repriseSection.style.display = 'block';
                    repriseSection.classList.add('page-break');
                }
            };
            
            window.onafterprint = function() {
                // Restaurer l'état d'affichage
                if (pvSection.style.display === 'block' && repriseSection.style.display === 'block') {
                    repriseSection.classList.remove('page-break');
                    showTable('pv');
                }
                
                document.body.classList.remove('print-pv-only', 'print-reprise-only');
            };
        });
    </script>
</body>
</html>